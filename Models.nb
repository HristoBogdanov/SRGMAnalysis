Cell["\<\
Pham-Zhang model
\
\>", "Text",
 CellChangeTimes->{{3.987642638872404*^9, 3.987642646038809*^9}, 
   3.9876426790068493`*^9},ExpressionUUID->"35b75bcc-1ced-0e46-8c8a-\
36261a26da3d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"phamZhang", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"issues", ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Beta]", "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "b"}], "*", "t"}], "]"}]}]}], ")"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c", "+", "a"}], ")"}], "*", "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "b"}], "*", "t"}], "]"}]}], ")"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "*", "b"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"b", "-", "\[Alpha]"}], ")"}]}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "\[Alpha]"}], "*", "t"}], "]"}], "-", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "b"}], "*", "t"}], "]"}]}], ")"}]}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "90"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", "1.1"}], "}"}], ",", "\[Beta]"}], "}"}], ",",
      "t"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9876426953090687`*^9, 3.987642695971485*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"93e4fe89-9898-0b46-b4bd-9603ac4db854"],

