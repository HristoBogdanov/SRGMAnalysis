Cell["\<\
Delayed S-shaped model m(t) = a(1-(1+b*t)Exp[-b*t])
\
\>", "Text",
 CellChangeTimes->{{3.9876420445977955`*^9, 
  3.9876421098672047`*^9}},ExpressionUUID->"29dd5822-4fe2-504e-937f-\
28fc30c26ea7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"delayedS", " ", "=", " ", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"issues", ",", 
     RowBox[{"a", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"b", "*", "t"}]}], ")"}], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "b"}], "*", "t"}], "]"}]}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "204"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"b", ",", "0.1"}], "}"}]}], "}"}], ",", "t"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.987642117119116*^9, 3.9876421520347767`*^9}, {
  3.9876421842304707`*^9, 3.9876421854832*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"8e9b0248-3029-4a4f-954b-6f75b71b4068"],

