Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"delayedS", " ", "=", " ", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"issues", ",", 
     RowBox[{"a", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"b", "*", "t"}]}], ")"}], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "b"}], "*", "t"}], "]"}]}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "204"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"b", ",", "0.1"}], "}"}]}], "}"}], ",", "t"}], "]"}]}], 
  ";"}]], "Input",
