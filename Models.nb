  RowBox[{"phamZhang", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"issues", ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Beta]", "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "b"}], "*", "t"}], "]"}]}]}], ")"}]}], ")"}], "*", 
