Cell["\<\
Inflection S-shaped model m(t) = a (1-Exp[-b*t]) / 1+ \[Beta]*Exp[-b*t]
\
\>", "Text",
 CellChangeTimes->{{3.987642411968321*^9, 
  3.9876424130398293`*^9}},ExpressionUUID->"a26f1b06-3b09-8947-97b4-\
9fbe71a31cb7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"inflection", " ", "=", " ", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"issues", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "b"}], "*", "t"}], "]"}]}], ")"}]}], ")"}], " ", "/",
       " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", " ", 
        RowBox[{"\[Beta]", "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "b"}], "*", "t"}], "]"}]}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "204"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"b", ",", "0.1"}], "}"}], ",", 
       RowBox[{"{", "\[Beta]", "}"}]}], "}"}], ",", " ", "t"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.987642453635664*^9, 3.9876424544224567`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"94e7afda-fb56-9446-a0ec-7689f365b0c8"],

